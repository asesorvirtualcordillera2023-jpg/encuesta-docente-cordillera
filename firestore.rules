rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Ajusta estas reglas a tu modelo de usuarios antes de producción.
    // Esta base permite usuarios autenticados anónimamente porque la app actual usa signInAnonymously().

    match /incidentes_data/institucion/tickets/{ticketId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['idStr', 'fecha', 'agente', 'usuario', 'asunto', 'categoria', 'prioridad', 'canal', 'estado'])
        && request.resource.data.asunto is string
        && request.resource.data.estado in ['Resuelto', 'Requiere Seguimiento'];
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    match /incidentes_data/institucion/directorio/{userId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /incidentes_data/institucion/config/{configId} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
